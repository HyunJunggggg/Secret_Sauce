<%- include('partials/header') %>

<div class="container">

  <div class="page-hero">
    <h1 class="hero-title">All Contributions</h1>
    <p class="hero-sub">Edit or remove interview posts from the community database</p>
  </div>

  <!-- ── Toast Notifications ── -->
  <% if (typeof query !== 'undefined' && query) { %>
    <% if (query.updated) { %>
    <div class="alert alert-success">✓ Interview updated successfully.</div>
    <% } %>
    <% if (query.deleted) { %>
    <div class="alert alert-warning">🗑 Interview deleted from the database.</div>
    <% } %>
  <% } %>

  <div class="contrib-header-row">
    <span class="contrib-count-badge"><%= interviews.length %> total post<%= interviews.length !== 1 ? 's' : '' %></span>
    <a href="/submit" class="btn-primary btn-sm">+ Add New</a>
  </div>

  <% if (interviews.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">📝</div>
      <h3>No contributions yet</h3>
      <p><a href="/submit">Share your first interview experience!</a></p>
    </div>
  <% } else { %>
    <div class="contrib-list">
      <% interviews.forEach(interview => { %>
        <div class="contrib-card" id="contrib-<%= interview.id %>">
          <div class="contrib-card-inner">
            <div class="contrib-info">
              <div class="card-tags" style="margin-bottom: 8px;">
                <span class="tag tag-company">🏢 <%= interview.company %></span>
                <span class="tag tag-role">💼 <%= interview.role %></span>
                <span class="tag tag-stage"><%= interview.stage %></span>
              </div>
              <p class="contrib-question"><%= interview.question %></p>
              <div class="contrib-meta">
                <span class="stars">
                  <% for(let i = 1; i <= 5; i++) { %>
                    <span class="star <%= i <= interview.frequency ? 'star-filled' : 'star-empty' %>">★</span>
                  <% } %>
                </span>
                <span class="meta-sep">·</span>
                <span>by <%= interview.author_name %></span>
                <span class="meta-sep">·</span>
                <span><%= new Date(interview.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
              </div>
            </div>
            <div class="contrib-actions">
              <a href="/interviews/<%= interview.id %>/edit" class="btn-secondary btn-sm">Edit</a>
              <!-- DELETE uses a hidden form + method-override for PUT/DELETE via HTML form -->
              <form action="/interviews/<%= interview.id %>?_method=DELETE" method="POST" class="delete-form"
                    onsubmit="return confirmDelete('<%= interview.company %>')">
                <button type="submit" class="btn-danger btn-sm">Delete</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

</div>

<%- include('partials/footer') %>
