<%- include('partials/header') %>

<div class="container">

  <!-- ── Page Hero ── -->
  <div class="page-hero">
    <h1 class="hero-title">Interview Experiences</h1>
    <p class="hero-sub">Browse real questions, tips, and answers shared by the community</p>
  </div>

  <!-- ── Success Banner ── -->
  <% if (typeof query !== 'undefined' && query && query.success) { %>
  <div class="alert alert-success">
    ✓ Your interview experience was submitted successfully — thanks for contributing!
  </div>
  <% } %>

  <!-- ── Stats Row ── -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-num stat-orange"><%= stats.total_interviews %></div>
      <div class="stat-label">Interviews Shared</div>
    </div>
    <div class="stat-card">
      <div class="stat-num stat-green"><%= stats.total_companies %></div>
      <div class="stat-label">Companies</div>
    </div>
    <div class="stat-card">
      <div class="stat-num stat-purple"><%= stats.total_roles %></div>
      <div class="stat-label">Job Roles</div>
    </div>
  </div>

  <!-- ── Search & Filters ── -->
  <form class="search-bar" action="/" method="GET" id="searchForm">
    <div class="search-field">
      <label class="field-label" for="search">Search</label>
      <input
        class="field-input"
        type="text"
        name="search"
        id="search"
        placeholder="Search questions, tips, companies..."
        value="<%= filters.search %>"
        autocomplete="off"
      />
    </div>
    <div class="filter-field">
      <label class="field-label" for="company">Company</label>
      <select class="field-input" name="company" id="company">
        <option value="">All Companies</option>
        <% companies.forEach(c => { %>
        <option value="<%= c.company %>" <%= filters.company.toLowerCase() === c.company.toLowerCase() ? 'selected' : '' %>>
          <%= c.company %>
        </option>
        <% }) %>
      </select>
    </div>
    <div class="filter-field">
      <label class="field-label" for="role">Role</label>
      <select class="field-input" name="role" id="role">
        <option value="">All Roles</option>
        <% roles.forEach(r => { %>
        <option value="<%= r.role %>" <%= filters.role.toLowerCase() === r.role.toLowerCase() ? 'selected' : '' %>>
          <%= r.role %>
        </option>
        <% }) %>
      </select>
    </div>
    <button type="submit" class="btn-search">Search</button>
    <% if (filters.search || filters.company || filters.role) { %>
    <a href="/" class="btn-clear">Clear</a>
    <% } %>
  </form>

  <!-- ── Results Count ── -->
  <div class="results-meta">
    <% if (filters.search || filters.company || filters.role) { %>
      <span><strong><%= interviews.length %></strong> result<%= interviews.length !== 1 ? 's' : '' %> found</span>
    <% } else { %>
      <span>Showing all <strong><%= interviews.length %></strong> interview<%= interviews.length !== 1 ? 's' : '' %></span>
    <% } %>
  </div>

  <!-- ── Interview Cards ── -->
  <% if (interviews.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">🔍</div>
      <h3>No results found</h3>
      <p>Try adjusting your search or filters, or <a href="/submit">share your own interview experience</a>.</p>
    </div>
  <% } else { %>
    <div class="cards-list">
      <% interviews.forEach(interview => { %>
        <div class="card" id="card-<%= interview.id %>">
          <div class="card-header">
            <div class="card-tags">
              <span class="tag tag-company">🏢 <%= interview.company %></span>
              <span class="tag tag-role">💼 <%= interview.role %></span>
              <span class="tag tag-stage"><%= interview.stage %></span>
            </div>
            <div class="card-meta-right">
              <span class="card-author">by <%= interview.author_name %></span>
            </div>
          </div>

          <h2 class="card-question"><%= interview.question %></h2>

          <div class="card-freq">
            <span class="freq-label">Frequency:</span>
            <span class="stars">
              <% for(let i = 1; i <= 5; i++) { %>
                <span class="star <%= i <= interview.frequency ? 'star-filled' : 'star-empty' %>">★</span>
              <% } %>
            </span>
          </div>

          <div class="card-toggle" onclick="toggleCard(<%= interview.id %>)" aria-expanded="false">
            <span class="toggle-text">View Answer &amp; Tips</span>
            <span class="toggle-icon" id="icon-<%= interview.id %>">⌄</span>
          </div>

          <div class="card-details" id="details-<%= interview.id %>">
            <div class="detail-label">Sample Answer &amp; Tips</div>
            <div class="detail-text"><%= interview.tips %></div>
            <div class="detail-footer">
              <span class="detail-date">
                Shared <%= new Date(interview.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
              </span>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

</div>

<%- include('partials/footer') %>
