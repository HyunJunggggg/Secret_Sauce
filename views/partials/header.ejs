<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Interview Secret Sauce</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/header.css" />
  <% if (typeof extraStyles !== 'undefined' && Array.isArray(extraStyles)) { %>
    <% extraStyles.forEach((href) => { %>
      <link rel="stylesheet" href="<%= href %>" />
    <% }) %>
  <% } %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>

<header class="navbar">
  <div class="navbar-inner">
    <a href="/" class="nav-brand">
      <img src="/logo.svg" alt="Interview Secret Sauce logo" class="nav-logo" />
    </a>
    <button class="nav-hamburger" id="navToggle" aria-label="Toggle menu">&#9776;</button>
    <nav class="nav-links" id="navLinks">
      <a href="/" class="nav-link <%= (title === 'Browse Interviews') ? 'active' : '' %>">
        <span class="nav-link-icon" aria-hidden="true">&#128269;</span>
        <span>Browse</span>
      </a>
      <a href="/submit" class="nav-link nav-link-cta <%= (title === 'Share an Interview') ? 'active' : '' %>">
        <span class="nav-link-icon" aria-hidden="true">+</span>
        <span>Share Interview</span>
      </a>
      <a href="/practice" class="nav-link <%= (title === 'Practice') ? 'active' : '' %>">
        <span class="nav-link-icon" aria-hidden="true">&#128214;</span>
        <span>Practice</span>
      </a>
    </nav>
  </div>
</header>

<main class="main-content">
